{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-dev",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\src\\MacroNex.Presentation\\MacroNex.Presentation.csproj",
        "-c",
        "Debug"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
