{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (MacroNex.Presentation - Watch)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}\\src\\MacroNex.Presentation\\MacroNex.Presentation.csproj",
        "run"
      ],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    }
  ]
}
